branches:
  - "main"
plugins:
  [
    [
      "@semantic-release/commit-analyzer",
      {
        preset: "conventionalCommits",
        releaseRules:
          [
            { type: "breaking", release: "major" },
            { type: "feat", release: "minor" },
            { type: "docs", release: "patch" },
            { type: "fix", release: "patch" },
            { type: "perf", release: "patch" },
            { type: "style", release: "patch" },
            { type: "chore", release: "patch" },
            { type: "test", release: "patch" },
            { type: "refactor", release: "patch" },
            { type: "build", release: "patch" },
            { type: "revert", release: "patch" },
            { type: "ci", release: "patch" },
          ],
      },
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        preset: "conventionalCommits",
        presetConfig:
          {
            types:
              [
                { type: "feat", section: ":sparkles: Features" },
                { type: "fix", section: ":bug: Bug Fixes" },
                { type: "perf", section: ":rocket: Performance Improvements" },
                { type: "revert", section: ":wastebasket: Reverts" },
                { type: "docs", section: ":memo: Documentation" },
                { type: "style", section: ":lipstick: Styles" },
                { type: "chore", section: ":wrench: Miscellaneous Chores" },
                { type: "refactor", section: ":recycle: Code Refactors" },
                { type: "test", section: ":white_check_mark: Tests" },
                {
                  type: "build",
                  section: ":building_construction: Build System",
                },
                { type: "ci", section: ":green_heart: CI/CD" },
                { type: "breaking", section: ":boom: Breaking Changes" },
              ],
          },
      },
    ],
    "@semantic-release/changelog",
    ["@semantic-release/git", { message: "changelog: ${nextRelease.version}" }],
    "@semantic-release/github",
  ]
tagFormat: "v${version}"
